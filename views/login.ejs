<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-slate-900 min-h-screen flex items-center justify-center p-4">

    <div class="bg-slate-800 w-full max-w-md rounded-2xl shadow-2xl border border-slate-700 overflow-hidden transform transition-all p-8">
        
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-emerald-500/10 text-emerald-400 mb-4 ring-8 ring-emerald-500/5">
                <i class="fa-solid fa-shield-halved text-2xl"></i>
            </div>
            <h2 class="text-2xl font-bold text-white tracking-tight">Iniciar Sesión</h2>
            <p class="text-slate-400 text-sm mt-1">Sistema de Control de Accesos - ESPE</p>
        </div>

        <form action="/auth/login" method="POST" class="space-y-6">
            
            <div>
                <label for="email" class="block text-sm font-medium text-slate-300 mb-2">Correo Electrónico</label>
                <div class="relative rounded-lg shadow-sm">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-500">
                        <i class="fa-solid fa-envelope"></i>
                    </div>
                    <input type="email" id="email" name="email" required
                        class="block w-full pl-10 pr-3 py-2.5 bg-slate-900 border border-slate-700 rounded-lg text-slate-200 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-colors text-sm" 
                        placeholder="tu_correo@espe.edu.ec">
                </div>
            </div>

            <div>
                <div class="flex justify-between items-center mb-2">
                    <label for="password" class="block text-sm font-medium text-slate-300">Contraseña</label>
                </div>
                <div class="relative rounded-lg shadow-sm">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-500">
                        <i class="fa-solid fa-lock"></i>
                    </div>
                    <input type="password" id="password" name="password" required
                        class="block w-full pl-10 pr-3 py-2.5 bg-slate-900 border border-slate-700 rounded-lg text-slate-200 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-colors text-sm"
                        placeholder="••••••••">
                </div>
            </div>

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="mb-6 p-3 rounded-lg bg-rose-500/10 border border-rose-500/20 text-rose-400 text-sm flex items-center space-x-2">
                    <i class="fa-solid fa-circle-exclamation flex-shrink-0"></i>
                    <span><%= error %></span>
                </div>
            <% } %>

            <button type="submit" 
                class="w-full flex justify-center py-3 px-4 border border-transparent rounded-lg shadow-sm text-sm font-semibold text-white bg-emerald-600 hover:bg-emerald-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-slate-800 focus:ring-emerald-500 transition-all duration-150 active:scale-[0.98]">
                Ingresar al Sistema
            </button>
        </form>
        
        <div class="relative my-6">
            <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-slate-700"></div></div>
            <div class="relative flex justify-center text-xs uppercase"><span class="bg-slate-800 px-2 text-slate-400">O también</span></div>
        </div>

        <a href="/auth/google" 
        class="w-full inline-flex justify-center items-center space-x-2 py-2.5 px-4 rounded-lg bg-slate-700 hover:bg-slate-600 border border-slate-600 text-sm font-semibold text-white transition-all duration-150">
            <i class="fa-brands fa-google text-amber-400"></i>
            <span>Iniciar sesión con Google</span>
        </a>
        
        <div class="mt-8 pt-6 border-t border-slate-700 text-center">
            <p class="text-sm text-slate-400">
                ¿No tienes una cuenta? 
                <a href="/register" class="font-medium text-emerald-400 hover:text-emerald-300 transition-colors ml-1">Regístrate aquí</a>
            </p>
        </div>

        <div class="relative my-6">
            <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-slate-700"></div></div>
            <div class="relative flex justify-center text-xs uppercase"><span class="bg-slate-800 px-2 text-slate-400">Entorno Centralizado (Kerberos)</span></div>
        </div>

        <div class="bg-slate-900/50 border border-slate-700/50 rounded-xl p-4 space-y-3">
            <p class="text-xs text-slate-400 text-center">Simulador de Single Sign-On (SSO) mediante KDC</p>
            <div class="grid grid-cols-2 gap-2">
                <button type="button" onclick="solicitarTicketKerberos()" 
                    class="py-2 px-3 text-xs font-medium rounded-lg bg-indigo-600 hover:bg-indigo-500 text-white transition-all text-center">
                    1. Emitir Ticket KDC
                </button>
                <button type="button" id="btnAccesoSSO" onclick="enviarTicketSSO()" disabled
                    class="py-2 px-3 text-xs font-medium rounded-lg bg-slate-700 text-slate-400 cursor-not-allowed transition-all text-center">
                    2. Acceder con Ticket
                </button>
            </div>
            <div id="statusKerberos" class="text-[11px] text-center text-slate-500 italic">No se ha solicitado ningún ticket.</div>
        </div>

        <script>
            let ticketAlmacenadoLocalmente = null;

            async function solicitarTicketKerberos() {
                const statusDiv = document.getElementById('statusKerberos');
                const btnAcceso = document.getElementById('btnAccesoSSO');
                
                // 👁️ TOMAMOS EL CORREO QUE ESTÁ ESCRITO EN TU INPUT REAL DE LOGIN
                const emailInput = document.getElementById('email').value;

                if (!emailInput) {
                    statusDiv.className = "text-[11px] text-center text-amber-400 font-medium";
                    statusDiv.innerText = "⚠️ Por favor, escribe primero tu correo en el campo de arriba.";
                    return;
                }

                try {
                    const response = await fetch('/kdc/solicitar-ticket', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ email: emailInput }) // Enviamos el correo real escrito
                    });
                    const resData = await response.json();
                    
                    if (resData.success) {
                        ticketAlmacenadoLocalmente = resData.ticket;
                        statusDiv.className = "text-[11px] text-center text-emerald-400 font-medium";
                        statusDiv.innerText = "🎟️ Ticket KDC emitido para tu usuario. Contraseña omitida.";
                        btnAcceso.removeAttribute('disabled');
                        btnAcceso.className = "py-2 px-3 text-xs font-medium rounded-lg bg-emerald-600 hover:bg-emerald-500 text-white cursor-pointer transition-all";
                    } else {
                        statusDiv.className = "text-[11px] text-center text-rose-400 font-medium";
                        statusDiv.innerText = "❌ KDC Denegado: " + resData.message;
                        btnAcceso.setAttribute('disabled', 'true');
                        btnAcceso.className = "py-2 px-3 text-xs font-medium rounded-lg bg-slate-700 text-slate-400 cursor-not-allowed";
                    }
                } catch (error) { 
                    statusDiv.innerText = "Error con el KDC."; 
                }
            }
            async function enviarTicketSSO() {
                const statusDiv = document.getElementById('statusKerberos');
                
                if (!ticketAlmacenadoLocalmente) return;

                try {
                    const response = await fetch('/auth/kerberos-login', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ ticket: ticketAlmacenadoLocalmente })
                    });
                    const data = await response.json();

                    if (data.success) {
                        statusDiv.innerText = "Validación exitosa. Redirigiendo...";
                        window.location.href = data.redirect;
                    } else {
                        statusDiv.className = "text-[11px] text-center text-rose-400 font-medium";
                        statusDiv.innerText = "❌ Denegado: " + data.message;
                    }
                } catch (error) {
                    statusDiv.innerText = "Error al validar el ticket.";
                }
            }
        </script>
        
    </div>

</body>
</html>